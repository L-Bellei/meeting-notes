    {
      "name": "Meetings — Orquestração",
      "description": "Pipeline: start → stop (captura+transcrição automática) → acompanhe status via GET /meetings/{id}. Alternativa: set-transcript dispara AI diretamente. process re-roda apenas a AI.",
      "item": [
        {
          "name": "Start recording",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/meetings/{{meeting_id}}/start",
              "host": ["{{base_url}}"],
              "path": ["api", "meetings", "{{meeting_id}}", "start"]
            },
            "description": "Inicia gravação via audio-service.\n\n→ 202: status muda para `recording`\n→ 503: audio-service indisponível\n→ 409: audio-service em estado conflitante\n→ 422: meeting já está em `recording`\n→ 404: meeting não existe"
          }
        },
        {
          "name": "Stop recording",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/meetings/{{meeting_id}}/stop",
              "host": ["{{base_url}}"],
              "path": ["api", "meetings", "{{meeting_id}}", "stop"]
            },
            "description": "Para a gravação e dispara pipeline em background:\nstop → transcribe (Whisper) → gera summary/key_points/tasks.\n\nAcompanhe o progresso fazendo GET no meeting e observando `status`:\npending → recording → transcribing → processing → completed (ou failed)"
          }
        },
        {
          "name": "Process (re-rodar AI)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/meetings/{{meeting_id}}/process",
              "host": ["{{base_url}}"],
              "path": ["api", "meetings", "{{meeting_id}}", "process"]
            },
            "description": "Re-roda apenas a geração de AI (summary + key_points + tasks) a partir do transcript já salvo.\n\nÚtil quando o pipeline anterior falhou na etapa de AI.\n\n→ 422: transcript vazio"
          }
        },
        {
          "name": "Set transcript (dispara AI)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transcript\": \"Discutimos os itens do sprint. João vai revisar o PR de autenticação até quinta. Maria assumirá a integração com o serviço de pagamento.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/meetings/{{meeting_id}}/transcript",
              "host": ["{{base_url}}"],
              "path": ["api", "meetings", "{{meeting_id}}", "transcript"]
            },
            "description": "Salva um transcript manualmente e dispara a geração de AI em background.\n\nÚtil para importar transcrições externas sem usar o audio-service.\n\n→ 400: JSON inválido\n→ 422: transcript vazio ou meeting em estado recording/transcribing"
          }
        }
      ]
    },
